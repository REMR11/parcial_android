<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Practice">

        <!-- LoginActivity is the Main Entry Launcher Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Practice">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity is the Patients List Board -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Practice" />

        <!-- RegistroActivity is the Patient Registration Form -->
        <activity
            android:name=".RegistroActivity"
            android:exported="false"
            android:theme="@style/Theme.Practice" />

        <!-- ConfirmacionActivity is the Intermediate Preview and Room Persistence -->
        <activity
            android:name=".ConfirmacionActivity"
            android:exported="false"
            android:theme="@style/Theme.Practice" />

        <!-- DetalleActivity is the Patient Read-Only Card Sheet -->
        <activity
            android:name=".DetalleActivity"
            android:exported="false"
            android:theme="@style/Theme.Practice" />

        <!-- DashboardActivity is the Hospital Metrics & Progress Ratios -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Practice" />

    </application>

</manifest>