<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Expediente Clínico"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Priority Badge Header -->
    <View
        android:id="@+id/viewPriorityBanner"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/priority_medium_bg"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <TextView
        android:id="@+id/tvDetailPrioridad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRIORIDAD: MEDIA"
        android:textColor="@color/priority_medium_text"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/viewPriorityBanner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/viewPriorityBanner" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewPriorityBanner">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDetailNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Paciente"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <!-- Grid-like list of details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATOS PERSONALES"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvDetailEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edad: 35 años"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailDui"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DUI: 00000000-0"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Teléfono: 7000-0000"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dirección: San Salvador"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATOS CLÍNICOS"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvDetailSintomas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Síntomas: Dolor abdominal"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailDiagnostico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Diagnóstico: Apendicitis"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailHospitalizacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hospitalización: Sí"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailExamenes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Exámenes de Laboratorio: Sí"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvDetailFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Registrado el: 22/05/2026 07:00 AM"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
